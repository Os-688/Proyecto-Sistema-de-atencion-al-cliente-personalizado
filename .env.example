# Copia este archivo como .env y completa los valores necesarios.
# Ejemplo:
#   Windows PowerShell: Copy-Item .env.example .env
#   Linux/Mac: cp .env.example .env

# ============================================================================
# SELECCION DE PROVEEDOR LLM (requerido)
# ============================================================================
# Define qué cliente de IA se usa. Valores posibles:
# - "openai"          : usa OpenAI GPT (recomendado para producción)
# - "google_ai_studio": usa Google Gemini con tokens gratuitos (recomendado para probar gratis)
# - "mock"            : modo simulación (sin API key, ideal para desarrollo)

LLM_PROVIDER=mock

# ============================================================================
# OPENAI (opcional)
# ============================================================================
# Requerido solo si LLM_PROVIDER=openai
OPENAI_API_KEY=sk-tu-api-key-aqui

# Opcionales (documentativos para futura parametrizacion)
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_TEMPERATURE=0.7
# OPENAI_MAX_TOKENS=500

# ============================================================================
# GOOGLE AI STUDIO (opcional - RECOMENDADO PARA PROBAR GRATIS)
# ============================================================================
# Requerido solo si LLM_PROVIDER=google_ai_studio
# Cómo obtenerlo:
# 1. Ve a https://aistudio.google.com
# 2. Inicia sesión con tu cuenta Google
# 3. Haz clic en "Get API key"
# 4. Copia y pega aquí
# NOTA: Google ofrece tokens gratuitos para probar Gemini. Ver README para límites.

GOOGLE_API_KEY=tu-google-api-key-aqui

# Opcionales (modelo por defecto: gemini-2.5-flash es rápido y económico)
# GOOGLE_MODEL=gemini-2.5-flash
# GOOGLE_TEMPERATURE=0.7
# GOOGLE_MAX_TOKENS=500
